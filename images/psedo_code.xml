<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 700 1080" width="700" height="1080" font-family="Arial, sans-serif">
######
# This file was developed with the assistance of OpenAI Codex (ChatGPT).
######
  <!-- # ===== DEFINITIONS (arrows, gradient, shadow) ===== -->
  <defs>
    <!-- # Arrow for connections -->
    <marker id="arrow" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#2E75B6"/>
    </marker>

    <!-- # Gradient for header -->
    <linearGradient id="headerGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#1B4F72"/>
      <stop offset="100%" style="stop-color:#2E75B6"/>
    </linearGradient>

    <!-- # Shadow effect -->
    <filter id="shadow" x="-2%" y="-2%" width="104%" height="104%">
      <feDropShadow dx="1" dy="1" stdDeviation="2" flood-opacity="0.15"/>
    </filter>
  </defs>

  <!-- # ===== TITLE ===== -->
  <rect x="150" y="10" width="400" height="45" rx="8" fill="url(#headerGrad)" filter="url(#shadow)"/>
  <text x="350" y="39" text-anchor="middle" fill="white" font-size="16" font-weight="bold">
    Pseudo-code global de l'application
  </text>

  <!-- # ===== STEP 1 ===== -->
  <rect x="100" y="75" width="500" height="50" rx="25" fill="#D4E6F1" stroke="#2E75B6" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="130" y="97" font-size="12" font-weight="bold" fill="#1B4F72">1.</text>
  <text x="150" y="97" font-size="12" fill="#1B4F72">DEBUT du programme</text>
  <line x1="350" y1="125" x2="350" y2="145" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 2 ===== -->
  <rect x="100" y="150" width="500" height="75" rx="6" fill="#EBF5FB" stroke="#2E75B6" filter="url(#shadow)"/>
  <text x="130" y="175" font-size="12" font-weight="bold" fill="#1B4F72">2.</text>
  <text x="150" y="170" font-size="11.5">OUVRIR base SQLite</text>
  <text x="150" y="188" font-size="11.5">CHARGER vocabulaire et index en memoire</text>
  <text x="150" y="206" font-size="11.5">CONSTRUIRE interface Tkinter</text>
  <line x1="350" y1="225" x2="350" y2="245" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 3 (LOOP) ===== -->
  <rect x="100" y="250" width="500" height="50" rx="6" fill="#D5F5E3" stroke="#27AE60" filter="url(#shadow)"/>
  <text x="130" y="279" font-size="12" font-weight="bold" fill="#1E8449">3.</text>
  <text x="150" y="279" font-size="12">TANT QUE l'application est ouverte FAIRE</text>
  <line x1="350" y1="300" x2="350" y2="320" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 4 ===== -->
  <rect x="100" y="325" width="500" height="75" rx="6" fill="#EBF5FB" stroke="#2E75B6" filter="url(#shadow)"/>
  <text x="130" y="350" font-size="12" font-weight="bold">4.</text>
  <text x="150" y="345" font-size="11.5">ATTENDRE une frappe clavier</text>
  <text x="150" y="363" font-size="11.5">DETECTER la langue du texte</text>
  <text x="150" y="381" font-size="11.5">METTRE A JOUR le contexte</text>
  <line x1="350" y1="400" x2="350" y2="420" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 5 ===== -->
  <rect x="100" y="425" width="500" height="75" rx="6" fill="#EBF5FB" stroke="#2E75B6" filter="url(#shadow)"/>
  <text x="130" y="450" font-size="12" font-weight="bold">5.</text>
  <text x="150" y="445" font-size="11.5">EXTRAIRE le mot sous le curseur</text>
  <text x="150" y="463" font-size="11.5">SI longueur du fragment suffisante ALORS</text>
  <text x="170" y="481" font-size="11.5">AFFICHER suggestions dans le popup</text>
  <line x1="350" y1="500" x2="350" y2="520" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 6 (IA delayed) ===== -->
  <rect x="100" y="525" width="500" height="75" rx="6" fill="#FEF9E7" stroke="#F39C12" filter="url(#shadow)"/>
  <text x="130" y="550" font-size="12" font-weight="bold">6.</text>
  <text x="150" y="545" font-size="11.5">ATTENDRE 650 ms sans frappe</text>
  <text x="150" y="563" font-size="11.5">SI delai ecoule ALORS</text>
  <text x="170" y="581" font-size="11.5">ENVOYER le bloc au modele IA (thread)</text>
  <line x1="350" y1="600" x2="350" y2="620" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 7 ===== -->
  <rect x="100" y="625" width="500" height="75" rx="6" fill="#FEF9E7" stroke="#F39C12" filter="url(#shadow)"/>
  <text x="130" y="650" font-size="12" font-weight="bold">7.</text>
  <text x="150" y="645" font-size="11.5">RECEVOIR la reponse du modele</text>
  <text x="150" y="663" font-size="11.5">NETTOYER la réponse</text>
  <text x="150" y="681" font-size="11.5">IGNORER si invalide, NOTIFIER si déjà correct</text>
  <line x1="350" y1="700" x2="350" y2="720" stroke="#2E75B6" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 8 ===== -->
  <rect x="100" y="725" width="500" height="75" rx="6" fill="#EBF5FB" stroke="#2E75B6" filter="url(#shadow)"/>
  <text x="130" y="750" font-size="12" font-weight="bold">8.</text>
  <text x="150" y="745" font-size="11.5">SOULIGNER les erreurs en rouge</text>
  <text x="150" y="763" font-size="11.5">AFFICHER le popup de correction</text>
  <text x="150" y="781" font-size="11.5">SI utilisateur appuie sur TAB ALORS APPLIQUER</text>

  <!-- # ===== LOOP BACK ===== -->
  <line x1="350" y1="800" x2="350" y2="830" stroke="#27AE60"/>
  <path d="M 350 830 L 70 830 L 70 275 L 95 275" fill="none" stroke="#27AE60" marker-end="url(#arrow)" stroke-dasharray="6,3"/>

  <!-- # ===== ARROW TO STEP 9 ===== -->
  <line x1="350" y1="830" x2="350" y2="865" stroke="#2E75B6" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- # ===== STEP 9 ===== -->
  <rect x="100" y="865" width="500" height="50" rx="25" fill="#D4E6F1" stroke="#2E75B6" filter="url(#shadow)"/>
  <text x="130" y="895" font-size="12" font-weight="bold">9.</text>
  <text x="150" y="895" font-size="12">FIN du programme</text>

  <!-- # ===== LEGEND ===== -->
  <rect x="100" y="940" width="500" height="120" rx="6" fill="#F8F9F9" stroke="#BDC3C7"/>
  <text x="120" y="960" font-size="12" font-weight="bold">Legende</text>

  <!-- # Legend items aligned -->
  <rect x="120" y="975" width="20" height="14" rx="3" fill="#EBF5FB" stroke="#2E75B6"/>
  <text x="150" y="987" font-size="11">Traitement local</text>

  <rect x="120" y="1000" width="20" height="14" rx="3" fill="#FEF9E7" stroke="#F39C12"/>
  <text x="150" y="1012" font-size="11">Appel IA (thread)</text>

  <rect x="120" y="1025" width="20" height="14" rx="6" fill="#D5F5E3" stroke="#27AE60"/>
  <text x="150" y="1037" font-size="11">Boucle principale</text>

</svg>
