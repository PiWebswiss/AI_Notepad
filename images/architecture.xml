<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 720" width="900" height="720" font-family="Arial, sans-serif">
######
# This file was developed with the assistance of OpenAI Codex (ChatGPT).
######
  <!-- ===== DEFINITIONS ===== -->
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#2E75B6"/>
    </marker>
    <marker id="arrowGreen" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#1E8449"/>
    </marker>
    <marker id="arrowOrange" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto-start-reverse">
      <polygon points="0 0, 10 3.5, 0 7" fill="#CA6F1E"/>
    </marker>
    <linearGradient id="headerGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#1B4F72"/>
      <stop offset="100%" style="stop-color:#2E75B6"/>
    </linearGradient>
    <filter id="shadow" x="-2%" y="-2%" width="104%" height="104%">
      <feDropShadow dx="1" dy="1" stdDeviation="2" flood-opacity="0.15"/>
    </filter>
  </defs>

  <!-- ===== TITLE ===== -->
  <rect x="200" y="10" width="500" height="40" rx="8" fill="url(#headerGrad)" filter="url(#shadow)"/>
  <text x="450" y="36" text-anchor="middle" fill="white" font-size="15" font-weight="bold">
    Architecture de AI Notepad
  </text>

  <!-- ===== HOST BOX ===== -->
  <rect x="30" y="75" width="840" height="500" rx="10" fill="#FAFBFC" stroke="#34495E" stroke-width="2" stroke-dasharray="6,3"/>
  <text x="50" y="95" font-size="12" font-weight="bold" fill="#34495E">HOST (Windows / Linux)</text>

  <!-- ===== USER ===== -->
  <circle cx="100" cy="190" r="30" fill="#FEF9E7" stroke="#F39C12" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="100" y="195" text-anchor="middle" font-size="11" font-weight="bold" fill="#7D6608">Utilisateur</text>

  <!-- ===== PYTHON APP CONTAINER ===== -->
  <rect x="180" y="110" width="660" height="280" rx="8" fill="#EBF5FB" stroke="#2E75B6" stroke-width="1.5"/>
  <text x="200" y="130" font-size="12" font-weight="bold" fill="#1B4F72">Python App (Tkinter)</text>

  <!-- ui.py (main) -->
  <rect x="250" y="150" width="140" height="60" rx="6" fill="#D4E6F1" stroke="#2E75B6" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="320" y="173" text-anchor="middle" font-size="12" font-weight="bold" fill="#1B4F72">ui.py</text>
  <text x="320" y="190" text-anchor="middle" font-size="10" fill="#34495E">interface + coordination</text>
  <text x="320" y="202" text-anchor="middle" font-size="10" fill="#34495E">boucle clavier</text>

  <!-- suggestions.py -->
  <rect x="210" y="250" width="130" height="50" rx="6" fill="#D5F5E3" stroke="#1E8449" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="275" y="272" text-anchor="middle" font-size="11" font-weight="bold" fill="#145A32">suggestions.py</text>
  <text x="275" y="288" text-anchor="middle" font-size="9" fill="#1E8449">ranking (freq + bigrammes)</text>

  <!-- text_utils.py -->
  <rect x="360" y="250" width="130" height="50" rx="6" fill="#D5F5E3" stroke="#1E8449" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="425" y="272" text-anchor="middle" font-size="11" font-weight="bold" fill="#145A32">text_utils.py</text>
  <text x="425" y="288" text-anchor="middle" font-size="9" fill="#1E8449">nettoyage + regex</text>

  <!-- db.py -->
  <rect x="510" y="250" width="130" height="50" rx="6" fill="#D5F5E3" stroke="#1E8449" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="575" y="272" text-anchor="middle" font-size="11" font-weight="bold" fill="#145A32">db.py</text>
  <text x="575" y="288" text-anchor="middle" font-size="9" fill="#1E8449">détection de langue</text>

  <!-- llm.py -->
  <rect x="660" y="250" width="130" height="50" rx="6" fill="#FDEBD0" stroke="#CA6F1E" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="725" y="272" text-anchor="middle" font-size="11" font-weight="bold" fill="#7D6608">llm.py</text>
  <text x="725" y="288" text-anchor="middle" font-size="9" fill="#CA6F1E">client Ollama HTTP</text>

  <!-- RAM data -->
  <rect x="300" y="330" width="240" height="40" rx="6" fill="#FADBD8" stroke="#C0392B" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="420" y="355" text-anchor="middle" font-size="11" font-weight="bold" fill="#78281F">RAM : vocab (150k) + bigrams (80k)</text>

  <!-- Arrows ui.py -> modules -->
  <line x1="300" y1="210" x2="275" y2="250" stroke="#2E75B6" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="340" y1="210" x2="425" y2="250" stroke="#2E75B6" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="370" y1="210" x2="575" y2="250" stroke="#2E75B6" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="390" y1="210" x2="725" y2="250" stroke="#2E75B6" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- Arrows suggestions.py / db.py -> RAM -->
  <line x1="310" y1="300" x2="380" y2="330" stroke="#1E8449" stroke-width="1.5" marker-end="url(#arrowGreen)"/>
  <line x1="540" y1="300" x2="480" y2="330" stroke="#1E8449" stroke-width="1.5" marker-end="url(#arrowGreen)"/>

  <!-- Arrow user -> ui.py -->
  <line x1="130" y1="190" x2="250" y2="180" stroke="#F39C12" stroke-width="2" marker-end="url(#arrow)"/>
  <rect x="151" y="178" width="78" height="14" fill="white"/>
  <text x="190" y="188" text-anchor="middle" font-size="9" fill="#7D6608">frappes clavier</text>

  <!-- ===== SQLite FILE ===== -->
  <rect x="240" y="420" width="360" height="60" rx="6" fill="#FCF3CF" stroke="#B7950B" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="420" y="445" text-anchor="middle" font-size="12" font-weight="bold" fill="#7D6608">SQLite : data/ainotepad_vocab.db</text>
  <text x="420" y="462" text-anchor="middle" font-size="10" fill="#7D6608">tables words + bigrams</text>

  <!-- Arrows SQLite <-> RAM -->
  <line x1="380" y1="420" x2="380" y2="375" stroke="#B7950B" stroke-width="1.5" marker-end="url(#arrowOrange)"/>
  <text x="275" y="405" font-size="9" fill="#7D6608">lecture au démarrage</text>
  <line x1="460" y1="375" x2="460" y2="420" stroke="#B7950B" stroke-width="1.5" marker-end="url(#arrowOrange)"/>
  <text x="470" y="405" font-size="9" fill="#7D6608">écriture à la fermeture</text>

  <!-- ===== seed_db.py (runs before app) ===== -->
  <rect x="650" y="420" width="180" height="60" rx="6" fill="#E8DAEF" stroke="#7D3C98" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="740" y="442" text-anchor="middle" font-size="11" font-weight="bold" fill="#4A235A">seed_db.py</text>
  <text x="740" y="458" text-anchor="middle" font-size="9" fill="#4A235A">wordfreq → SQLite</text>
  <text x="740" y="472" text-anchor="middle" font-size="9" fill="#4A235A">(1er lancement)</text>
  <line x1="650" y1="450" x2="600" y2="450" stroke="#7D3C98" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- ===== DOCKER BOX ===== -->
  <rect x="30" y="600" width="840" height="100" rx="10" fill="#EAECEE" stroke="#34495E" stroke-width="2" stroke-dasharray="6,3"/>
  <text x="50" y="622" font-size="12" font-weight="bold" fill="#34495E">DOCKER</text>

  <!-- Ollama container -->
  <rect x="280" y="635" width="340" height="50" rx="6" fill="#FDEBD0" stroke="#CA6F1E" stroke-width="1.5" filter="url(#shadow)"/>
  <text x="450" y="657" text-anchor="middle" font-size="12" font-weight="bold" fill="#7D6608">Ollama server (port 11434)</text>
  <text x="450" y="673" text-anchor="middle" font-size="10" fill="#CA6F1E">modèle Gemma 3 — GPU (auto) ou CPU</text>

  <!-- Bidirectional HTTP: request (llm.py -> Ollama) + response (Ollama -> llm.py) -->
  <line x1="725" y1="300" x2="600" y2="635" stroke="#CA6F1E" stroke-width="2" stroke-dasharray="4,2" marker-start="url(#arrowOrange)" marker-end="url(#arrowOrange)"/>
  <rect x="582" y="518" width="114" height="18" fill="white"/>
  <text x="639" y="530" text-anchor="middle" font-size="9" fill="#CA6F1E">HTTP localhost:11434</text>

  <!-- ===== LEGEND ===== -->
  <rect x="30" y="540" width="840" height="30" rx="4" fill="#ffffff" stroke="#BDC3C7" stroke-width="1"/>
  <rect x="50" y="548" width="14" height="14" fill="#D4E6F1" stroke="#2E75B6"/>
  <text x="70" y="559" font-size="10" fill="#34495E">Interface</text>
  <rect x="135" y="548" width="14" height="14" fill="#D5F5E3" stroke="#1E8449"/>
  <text x="155" y="559" font-size="10" fill="#34495E">Traitement local</text>
  <rect x="255" y="548" width="14" height="14" fill="#FDEBD0" stroke="#CA6F1E"/>
  <text x="275" y="559" font-size="10" fill="#34495E">IA / LLM</text>
  <rect x="335" y="548" width="14" height="14" fill="#FCF3CF" stroke="#B7950B"/>
  <text x="355" y="559" font-size="10" fill="#34495E">Base SQLite</text>
  <rect x="430" y="548" width="14" height="14" fill="#FADBD8" stroke="#C0392B"/>
  <text x="450" y="559" font-size="10" fill="#34495E">Mémoire RAM</text>
  <rect x="525" y="548" width="14" height="14" fill="#E8DAEF" stroke="#7D3C98"/>
  <text x="545" y="559" font-size="10" fill="#34495E">Initialisation</text>
  <rect x="625" y="548" width="14" height="14" fill="#FEF9E7" stroke="#F39C12"/>
  <text x="645" y="559" font-size="10" fill="#34495E">Utilisateur</text>

</svg>
