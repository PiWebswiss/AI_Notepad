# The AI model used by the application for corrections and suggestions.
OLLAMA_MODEL=gemma3:4B

# --- Ollama inference tuning (optional) ---
# Safety cap on generated tokens. The model stops naturally; this is just a ceiling.
# OLLAMA_NUM_PREDICT=900
# Context window size. Bigger = more memory use (KV cache); smaller = faster prefill.
# OLLAMA_NUM_CTX=2048
# Sampling temperature. 0.0 = deterministic, good for spell/grammar checking.
# OLLAMA_TEMPERATURE=0.0
